rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      incoming().keys().hasAll(['uid', 'email', 'createdAt', 'role']) &&
                      incoming().role == 'user';
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin']);
    }

    // User prompts
    match /users/{userId}/prompts/{promptId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      incoming().userId == request.auth.uid &&
                      incoming().content is string &&
                      incoming().content.size() <= 10000;
      allow update: if isOwner(userId) && 
                      incoming().userId == existing().userId &&
                      incoming().diff(existing()).affectedKeys().hasAny(['title', 'content', 'tags', 'updatedAt']);
      allow delete: if isOwner(userId);
    }
  }
}
